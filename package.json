{
  "name": "code-triage",
  "version": "0.1.0",
  "description": "Monitor CodeRabbit review comments and action them with Claude Code",
  "type": "module",
  "bin": {
    "code-triage": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "build:web": "cd web && yarn build",
    "build:all": "yarn build && yarn build:web",
    "dev": "tsc --watch",
    "dev:web": "cd web && yarn dev",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "coderabbit",
    "claude",
    "code-review",
    "github"
  ],
  "license": "MIT",
  "dependencies": {
    "ink": "^7.0.0",
    "react": "^19.2.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "typescript": "^5.8.0"
  }
}
