#!/bin/sh
# Run lint and typecheck before every commit.
# Installed automatically via `yarn prepare` (sets core.hooksPath).

echo "Running pre-commit checks..."

yarn lint --max-warnings 0 && yarn typecheck

if [ $? -ne 0 ]; then
  echo ""
  echo "Pre-commit checks failed. Fix the errors above and try again."
  echo "To skip (not recommended): git commit --no-verify"
  exit 1
fi
